<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BookCollector.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
    xmlns:local="clr-namespace:BookCollector"
    xmlns:views="clr-namespace:BookCollector.Views"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Shell.FlyoutBehavior="Flyout"
    Title="{x:Static localization:StringResources.ApplicationTitle}">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent Title="{x:Static localization:StringResources.Settings}"
                  ContentTemplate="{DataTemplate views:SettingsView}"/>

    <Shell.FlyoutFooter>
        <HorizontalStackLayout HorizontalOptions="Center"
                           Margin="10">
            <Label Text="{x:Static localization:StringResources.ApplicationTitle}"/>
            <Label Text=", "/>
            <Label Text="{Binding Year}"/>
        </HorizontalStackLayout>
    </Shell.FlyoutFooter>
    
</Shell>
