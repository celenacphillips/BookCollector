<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BookCollector.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
    xmlns:local="clr-namespace:BookCollector"
    xmlns:mainViews="clr-namespace:BookCollector.Views.Main"
    xmlns:libraryViews="clr-namespace:BookCollector.Views.Library"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Shell.FlyoutBehavior="Flyout"
    Title="{x:Static localization:AppStringResources.ApplicationTitle}">

    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid>
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor"
                                        Value="{DynamicResource Primary}" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="5*" />
                </Grid.ColumnDefinitions>

                <Image Source="{Binding Icon}"
                   HorizontalOptions="Center"
                   Margin="20,20,0,20"
                   HeightRequest="30"
                   Grid.Row="0" Grid.Column="0"/>
                <Label Text="{Binding Title}"
                   Padding="10"
                   FontAttributes="Bold"
                   VerticalTextAlignment="Center"
                   Grid.Row="0" Grid.Column="1"/>

            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <FlyoutItem FlyoutDisplayOptions="AsMultipleItems">
        <Tab Title="{x:Static localization:AppStringResources.Library}">
            <ShellContent Title="{x:Static localization:AppStringResources.Reading}"
                      ContentTemplate="{DataTemplate libraryViews:ReadingView}"/>

            <ShellContent Title="{x:Static localization:AppStringResources.ToBeRead}"
                      ContentTemplate="{DataTemplate libraryViews:ToBeReadView}"/>

            <ShellContent Title="{x:Static localization:AppStringResources.Read}"
                      ContentTemplate="{DataTemplate libraryViews:ReadView}"/>

            <ShellContent Title="{x:Static localization:AppStringResources.AllBooks}"
                      ContentTemplate="{DataTemplate libraryViews:AllBooksView}"/>
        </Tab>
    </FlyoutItem>

    <ShellContent Title="{x:Static localization:AppStringResources.Settings}"
                  ContentTemplate="{DataTemplate mainViews:SettingsView}"/>

    <Shell.FlyoutFooter>
        <HorizontalStackLayout HorizontalOptions="Center"
                           Margin="10">
            <Label Text="{x:Static localization:AppStringResources.ApplicationTitle}"
                   Style="{StaticResource Header}"/>
            <Label Text=", "
                   Style="{StaticResource Header}"/>
            <Label Text="{Binding Year}"
                   Style="{StaticResource Header}"/>
        </HorizontalStackLayout>
    </Shell.FlyoutFooter>
    
</Shell>
