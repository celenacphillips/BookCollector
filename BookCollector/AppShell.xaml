<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BookCollector.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
    xmlns:local="clr-namespace:BookCollector"
    xmlns:mainViews="clr-namespace:BookCollector.Views.Main"
    xmlns:libraryViews="clr-namespace:BookCollector.Views.Library"
    xmlns:groupingsViews="clr-namespace:BookCollector.Views.Groupings"
    xmlns:statisticsViews="clr-namespace:BookCollector.Views.Statistics"
    xmlns:settingsViews="clr-namespace:BookCollector.Views.Settings"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Shell.FlyoutBehavior="Flyout"
    Title="{x:Static localization:AppStringResources.ApplicationTitle}">

    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid>
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </VisualState.Setters>
                            </VisualState>
                            
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor"
                                            Value="{DynamicResource Primary}" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="5*" />
                </Grid.ColumnDefinitions>

                <Image Source="{Binding Icon}"
                       HorizontalOptions="Center"
                       Margin="20,20,0,20"
                       HeightRequest="30"
                       Grid.Row="0" Grid.Column="0"/>
                <Label Text="{Binding Title}"
                       Padding="10"
                       FontAttributes="Bold"
                       VerticalTextAlignment="Center"
                       Grid.Row="0" Grid.Column="1"/>

            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <FlyoutItem FlyoutDisplayOptions="AsMultipleItems">
        <Tab Title="{x:Static localization:AppStringResources.Library}">
            <ShellContent Title="{x:Static localization:AppStringResources.Reading}"
                          ContentTemplate="{DataTemplate libraryViews:ReadingView}"/>

            <ShellContent Title="{x:Static localization:AppStringResources.ToBeRead}"
                          ContentTemplate="{DataTemplate libraryViews:ToBeReadView}"/>

            <ShellContent Title="{x:Static localization:AppStringResources.Read}"
                          ContentTemplate="{DataTemplate libraryViews:ReadView}"/>

            <ShellContent Title="{x:Static localization:AppStringResources.AllBooks}"
                          ContentTemplate="{DataTemplate libraryViews:AllBooksView}"/>
        </Tab>
    </FlyoutItem>

    <FlyoutItem FlyoutDisplayOptions="AsMultipleItems">
        <Tab Title="{x:Static localization:AppStringResources.Groupings}">
            <ShellContent Title="{x:Static localization:AppStringResources.Collections}"
                          ContentTemplate="{DataTemplate groupingsViews:CollectionsView}"/>

            <ShellContent Title="{x:Static localization:AppStringResources.Genres}"
                          ContentTemplate="{DataTemplate groupingsViews:GenresView}"/>

            <ShellContent Title="{x:Static localization:AppStringResources.Series}"
                          ContentTemplate="{DataTemplate groupingsViews:SeriesView}"/>

            <ShellContent Title="{x:Static localization:AppStringResources.Authors}"
                          ContentTemplate="{DataTemplate groupingsViews:AuthorsView}"/>

            <ShellContent Title="{x:Static localization:AppStringResources.Locations}"
                          ContentTemplate="{DataTemplate groupingsViews:LocationsView}"/>
        </Tab>
    </FlyoutItem>

    <FlyoutItem FlyoutDisplayOptions="AsMultipleItems">
        <Tab Title="{x:Static localization:AppStringResources.Statistics}">
            <ShellContent Title="{x:Static localization:AppStringResources.Library}"
                          ContentTemplate="{DataTemplate statisticsViews:LibraryStatisticsView}"/>

            <ShellContent Title="{x:Static localization:AppStringResources.Wishlist}"
                          ContentTemplate="{DataTemplate statisticsViews:WishListStatisticsView}"/>

            <ShellContent Title="{x:Static localization:AppStringResources.ReadingData}"
                          ContentTemplate="{DataTemplate statisticsViews:ReadingDataView}"/>
        </Tab>
    </FlyoutItem>

    <ShellContent Title="{x:Static localization:AppStringResources.Wishlist}"
                  ContentTemplate="{DataTemplate mainViews:WishListView}"/>

    <ShellContent Title="{x:Static localization:AppStringResources.Export_Import}"
                  ContentTemplate="{DataTemplate mainViews:ExportImportView}"/>

    <FlyoutItem FlyoutDisplayOptions="AsMultipleItems">
        <Tab Title="{x:Static localization:AppStringResources.Settings}">
            <ShellContent Title="{x:Static localization:AppStringResources.MainSettings}"
                          ContentTemplate="{DataTemplate settingsViews:MainSettingsView}"/>

            <ShellContent Title="{x:Static localization:AppStringResources.ToggleSettings}"
                          ContentTemplate="{DataTemplate settingsViews:ToggleSettingsView}"/>
        </Tab>
    </FlyoutItem>

    <Shell.FlyoutFooter>
        <HorizontalStackLayout HorizontalOptions="Center"
                               Margin="10">
            <Label Text="{x:Static localization:AppStringResources.ApplicationTitle}"
                   Style="{StaticResource Header}"/>
            <Label Text=", "
                   Style="{StaticResource Header}"/>
            <Label Text="{Binding Year}"
                   Style="{StaticResource Header}"/>
        </HorizontalStackLayout>
    </Shell.FlyoutFooter>
    
</Shell>
