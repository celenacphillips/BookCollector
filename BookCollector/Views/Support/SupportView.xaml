<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
             x:Class="BookCollector.Views.Support.SupportView"
             Title="{x:Static localization:AppStringResources.Support}">

    <VerticalStackLayout Margin="20"
                         HorizontalOptions="Center">
        <Label Text="{x:Static localization:AppStringResources.SupportInfoText}"
               Margin="10,0"/>
        <Button Text="{x:Static localization:AppStringResources.Email}"
                Margin="10,30"
                Clicked="OnEmailButtonClicked"/>
    </VerticalStackLayout>
</ContentPage>