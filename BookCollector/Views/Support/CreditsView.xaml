<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BookCollector.Views.Support.CreditsView"
             xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
             Title="{x:Static localization:AppStringResources.Credits}">

    <VerticalStackLayout Margin="20,0">
        <Image Source="{AppThemeBinding Light=pictogrammers_full_black.svg, Dark=pictogrammers_full_white.svg}"/>
        <Label HorizontalTextAlignment="Center"
               Margin="10,0">
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="{x:Static localization:AppStringResources.PictogrammersCredit}" />
                    <Span Text="https://pictogrammers.com/"
                          TextColor="{DynamicResource Primary}"
                          TextDecorations="Underline">
                        <Span.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TapCommand}"
                                                  CommandParameter="https://pictogrammers.com/" />
                        </Span.GestureRecognizers>
                    </Span>
                </FormattedString>
            </Label.FormattedText>
        </Label>
    </VerticalStackLayout>
</ContentPage>