<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="BookCollector.Views.Groupings.ExistingBooksView"
             xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
             xmlns:viewModel="clr-namespace:BookCollector.ViewModels.Groupings"
             xmlns:controls="clr-namespace:BookCollector.Views.Controls.Book"
             x:DataType="viewModel:ExistingBooksViewModel"
             x:Name="ExistingBooksPage"
             Title="{Binding ViewTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/filter_icon_light.svg, Dark=Icons/filter_icon_dark.svg}"
                     Command="{Binding FilterPopupCommand}"/>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/sort_icon_light.svg, Dark=Icons/sort_icon_dark.svg}"
                     Command="{Binding SortPopupCommand}"/>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/info_icon_light.svg, Dark=Icons/info_icon_dark.svg}"
                     Command="{Binding InfoPopupCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid>

        <!-- Main Content -->
        <StackLayout>

            <RefreshView IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshCommand}">

                <VerticalStackLayout IsVisible="{Binding IsVisible}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Label Text="{x:Static localization:AppStringResources.AddExistingBook}"
                               TextColor="{DynamicResource Primary}"
                               Style="{DynamicResource SubTitle}"
                               Margin="20,0,0,0"
                               Grid.Column="0" Grid.Row="0"/>
                        <Label Text="{Binding TotalBooksString}"
                               HorizontalOptions="End"
                               Margin="0,0,20,0"
                               TextColor="{DynamicResource Primary}"
                               Style="{DynamicResource SubTitle}"
                               Grid.Column="1" Grid.Row="0"/>
                    </Grid>

                    <ScrollView>
                        <VerticalStackLayout Padding="10">
                            <SearchBar Placeholder="{x:Static localization:AppStringResources.SearchBooks}"
                                       Text="{Binding SearchString}">
                                <SearchBar.Behaviors>
                                    <toolkit:EventToCommandBehavior Command="{Binding BookSearchOnTitleCommand}"
                                                                    CommandParameter="{Binding SearchString}"
                                                                    EventName="TextChanged"
                                                                    BindingContext="{Binding BindingContext, Source={x:Reference ExistingBooksPage}}"/>
                                </SearchBar.Behaviors>
                            </SearchBar>

                            <controls:ExistingBookCollectionList/>

                        </VerticalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>
            </RefreshView>

        </StackLayout>
        <!-- Main Content -->
        
        <!-- Activity Indicator -->
        <Grid IsVisible="{Binding IsBusy}"
              BackgroundColor="Gray"
              Opacity="0.5">

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
        </Grid>
        <!-- Activity Indicator -->
    </Grid>

</ContentPage>