<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BookCollector.Views.Groupings.LocationsView"
             xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
             xmlns:viewModel="clr-namespace:BookCollector.ViewModels.Groupings"
             xmlns:controls="clr-namespace:BookCollector.Views.Controls"
             x:DataType="viewModel:LocationsViewModel"
             Title="{x:Static localization:AppStringResources.Locations}">

    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/filter_icon_light.svg, Dark=Icons/filter_icon_dark.svg}"
                     Command="{Binding FilterPopupCommand}"
                     IsEnabled="False"/>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/sort_icon_light.svg, Dark=Icons/sort_icon_dark.svg}"
                     Command="{Binding SortPopupCommand}"
                     IsEnabled="False"/>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/info_icon_light.svg, Dark=Icons/info_icon_dark.svg}"
                     Command="{Binding InfoPopupCommand}"
                     IsEnabled="False"/>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/plus_icon_light.svg, Dark=Icons/plus_icon_light.svg}"
                     Command="{Binding AddLocationCommand}"
                     IsEnabled="False"/>
    </ContentPage.ToolbarItems>

    <VerticalStackLayout>
        <Label 
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>