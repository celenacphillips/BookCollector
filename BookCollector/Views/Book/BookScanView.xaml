<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:scan="clr-namespace:BarcodeScanner.Mobile;assembly=BarcodeScanner.Mobile.Maui"
             xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
             x:Class="BookCollector.Views.Book.BookScanView">

    <StackLayout>
        <RefreshView IsEnabled="False">
            <ScrollView>
                <scan:CameraView HorizontalOptions="Fill"
                                 VerticalOptions="Fill"
                                 OnDetected="CameraView_OnDetected"
                                 TorchOn="False"
                                 VibrationOnDetected="True"
                                 ScanInterval="50"
                                 x:Name="barcodeScannerView"/>
            </ScrollView>
        </RefreshView>
    </StackLayout>
</ContentPage>