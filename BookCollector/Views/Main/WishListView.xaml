<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
             xmlns:viewModel="clr-namespace:BookCollector.ViewModels.Main"
             xmlns:controls="clr-namespace:BookCollector.Views.Controls.WishListBook"
             xmlns:activityControls="clr-namespace:BookCollector.Views.Controls"
             x:DataType="viewModel:WishListViewModel"
             x:Class="BookCollector.Views.Main.WishListView"
             x:Name="WishListPage"
             Title="{x:Static localization:AppStringResources.Wishlist}">

    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/filter_icon_light.svg, Dark=Icons/filter_icon_dark.svg}"
                     Command="{Binding FilterPopupCommand}"/>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/sort_icon_light.svg, Dark=Icons/sort_icon_dark.svg}"
                     Command="{Binding SortPopupCommand}"/>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/share_icon_light.svg, Dark=Icons/share_icon_dark.svg}"
                     Command="{Binding ShareListCommand}"/>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/info_icon_light.svg, Dark=Icons/info_icon_dark.svg}"
                     Command="{Binding InfoPopupCommand}"/>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/book_add_light.svg, Dark=Icons/book_add_dark.svg}"
                     Command="{Binding AddWishListBookCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid>

        <!-- Main Content -->
        <StackLayout>

            <RefreshView IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshCommand}">

                <VerticalStackLayout IsVisible="{Binding IsVisible}">
                    <Label Text="{Binding TotalBooksString}"
                           HorizontalOptions="End"
                           Margin="0,0,20,0"
                           TextColor="{DynamicResource Primary}"
                           Style="{StaticResource SubTitle}"/>

                    <ScrollView>
                        <!-- This is needed to allow the refresh view to work. -->

                        <VerticalStackLayout Padding="10">
                            <SearchBar Placeholder="{x:Static localization:AppStringResources.SearchBooks}"
                                       Text="{Binding Searchstring}">
                                <SearchBar.Behaviors>
                                    <toolkit:EventToCommandBehavior Command="{Binding BookSearchOnTitleCommand}"
                                                                    CommandParameter="{Binding Searchstring}"
                                                                    EventName="TextChanged"
                                                                    BindingContext="{Binding BindingContext, Source={x:Reference WishListPage}}"/>
                                </SearchBar.Behaviors>
                            </SearchBar>

                            <controls:WishListBookCollectionList/>

                        </VerticalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>
            </RefreshView>
        </StackLayout>

        <!-- Activity Indicator -->
        <activityControls:LoadingControl/>
        <!-- Activity Indicator -->
    </Grid>
</ContentPage>