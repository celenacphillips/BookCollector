<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
             x:Class="BookCollector.Views.Series.SeriesMainView"
             xmlns:viewModel="clr-namespace:BookCollector.ViewModels.Series"
             x:DataType="viewModel:SeriesMainViewModel"
             xmlns:bookControls="clr-namespace:BookCollector.Views.Controls.Book"
             x:Name="SeriesMainPage"
             Title="{Binding ViewTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/filter_icon_light.svg, Dark=Icons/filter_icon_dark.svg}"
                     Command="{Binding FilterPopupCommand}"/>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/sort_icon_light.svg, Dark=Icons/sort_icon_dark.svg}"
                     Command="{Binding SortPopupCommand}"/>
        <ToolbarItem IconImageSource="{AppThemeBinding Light=Icons/info_icon_light.svg, Dark=Icons/info_icon_dark.svg}"
                     Command="{Binding InfoPopupCommand}"/>
        <ToolbarItem Text="{x:Static localization:AppStringResources.AddNewBook}"
                     Order="Secondary"
                     Command="{Binding AddNewBookCommand}"/>
        <ToolbarItem Text="{x:Static localization:AppStringResources.AddExistingBook}"
                     Order="Secondary"
                     Command="{Binding AddExistingBookCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid>

        <!-- Main Content -->
        <StackLayout>

            <RefreshView IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshCommand}">

                <VerticalStackLayout>
                    <Label Text="{Binding TotalBooksstring}"
                           HorizontalOptions="End"
                           Margin="0,0,20,0"
                           TextColor="{StaticResource Primary}"
                           Style="{StaticResource SubTitle}"/>

                    <ScrollView>
                        <!-- This is needed to allow the refresh view to work. -->
                        <VerticalStackLayout  Padding="10">
                            <SearchBar Placeholder="{x:Static localization:AppStringResources.SearchBooks}"
                                       Text="{Binding Searchstring}">
                                <SearchBar.Behaviors>
                                    <toolkit:EventToCommandBehavior Command="{Binding BookSearchOnTitleCommand}"
                                                                    CommandParameter="{Binding Searchstring}"
                                                                    EventName="TextChanged"
                                                                    BindingContext="{Binding BindingContext, Source={x:Reference SeriesMainPage}}"/>
                                </SearchBar.Behaviors>
                            </SearchBar>

                            <bookControls:BookCollectionList/>

                        </VerticalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>
            </RefreshView>

        </StackLayout>
        <!-- Main Content -->

        <!-- Activity Indicator -->
        <Grid IsVisible="{Binding IsBusy}"
              BackgroundColor="Gray"
              Opacity="0.5">

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
        </Grid>
        <!-- Activity Indicator -->
    </Grid>
    
</ContentPage>