<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
               xmlns:viewModel="clr-namespace:BookCollector.ViewModels.Popups"
               xmlns:controls="clr-namespace:BookCollector.Views.Controls"
               x:DataType="viewModel:FilterPopupViewModel"
               x:Class="BookCollector.Views.Popups.FilterPopup"
               CanBeDismissedByTappingOutsideOfPopup="True"
               WidthRequest="{Binding PopupWidth}"
               MaximumHeightRequest="{Binding PopupHeight}"
               BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"
               Margin="0">

    <Grid HorizontalOptions="Center"
          Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Label Text="{x:Static localization:AppStringResources.FilterBy}"
                   Style="{DynamicResource Header}"
                   FontSize="Subtitle"
                   HorizontalOptions="Center"
                   VerticalOptions="End"
                   Grid.Row="0" Grid.Column="0"/>

            <HorizontalStackLayout Grid.Row="0" Grid.Column="1">
                <ImageButton Padding="10"
                             Margin="5"
                             HorizontalOptions="Center"
                             Command="{Binding ResetCommand}">
                    <ImageButton.Source>
                        <FontImageSource FontFamily="MaterialDesignIcons"
                                         Glyph="&#xF099B;"
                                         Size="28"
                                         Color="{DynamicResource TextOnPrimaryColor}" />
                    </ImageButton.Source>
                </ImageButton>

                <ImageButton HorizontalOptions="End"
                             Padding="10"
                             Margin="5"
                             Command="{Binding CloseCommand}">
                    <ImageButton.Source>
                        <FontImageSource FontFamily="MaterialDesignIcons"
                                         Glyph="&#xF0193;"
                                         Size="28"
                                         Color="{DynamicResource TextOnPrimaryColor}" />
                    </ImageButton.Source>
                </ImageButton>
            </HorizontalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1" Grid.Column="0"
                    Margin="10,20,10,0"
                    VerticalOptions="Start">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Favorite -->
                <Label Text="{x:Static localization:AppStringResources.Favorite}"
                       VerticalTextAlignment="Center"
                       IsVisible="{Binding FavoriteVisible}"
                       Padding="0,0,10,0"
                       Grid.Row="0" Grid.Column="0"/>

                <Button Text="{Binding FavoriteOption}"
                        Style="{DynamicResource PickerButton}"
                        Command="{Binding FavoriteChangedCommand}"
                        IsVisible="{Binding FavoriteVisible}"
                        Margin="0,10"
                        Grid.Row="0" Grid.Column="1"/>

                <!-- Author -->
                <Label Text="{x:Static localization:AppStringResources.Authors}"
                       VerticalTextAlignment="Center"
                       IsVisible="{Binding AuthorVisible}"
                       Padding="0,0,10,0"
                       Grid.Row="1" Grid.Column="0"/>

                <Button Text="{Binding AuthorOption}"
                        Style="{DynamicResource PickerButton}"
                        Command="{Binding AuthorChangedCommand}"
                        IsVisible="{Binding AuthorVisible}"
                        Margin="0,10"
                        Grid.Row="1" Grid.Column="1"/>

                <!-- Publisher -->
                <Label Text="{x:Static localization:AppStringResources.BookPublisher}"
                       VerticalTextAlignment="Center"
                       IsVisible="{Binding PublisherVisible}"
                       Padding="0,0,10,0"
                       Grid.Row="2" Grid.Column="0"/>

                <Button Text="{Binding PublisherOption}"
                        Style="{DynamicResource PickerButton}"
                        Command="{Binding PublisherChangedCommand}"
                        IsVisible="{Binding PublisherVisible}"
                        Margin="0,10"
                        Grid.Row="2" Grid.Column="1"/>

                <!-- Publish Year -->
                <Label Text="{x:Static localization:AppStringResources.BookPublishYear}"
                       VerticalTextAlignment="Center"
                       IsVisible="{Binding PublishYearVisible}"
                       Padding="0,0,10,0"
                       Grid.Row="3" Grid.Column="0"/>

                <Button Text="{Binding PublishYearOption}"
                        Style="{DynamicResource PickerButton}"
                        Command="{Binding PublishYearChangedCommand}"
                        IsVisible="{Binding PublishYearVisible}"
                        Margin="0,10"
                        Grid.Row="3" Grid.Column="1"/>

                <!-- Format -->
                <Label Text="{x:Static localization:AppStringResources.BookFormat}"
                       VerticalTextAlignment="Center"
                       IsVisible="{Binding FormatVisible}"
                       Padding="0,0,10,0"
                       Grid.Row="4" Grid.Column="0"/>

                <Button Text="{Binding FormatOption}"
                        Style="{DynamicResource PickerButton}"
                        Command="{Binding FormatChangedCommand}"
                        IsVisible="{Binding FormatVisible}"
                        Margin="0,10"
                        Grid.Row="4" Grid.Column="1"/>

                <!-- Language -->
                <Label Text="{x:Static localization:AppStringResources.BookLanguage}"
                       VerticalTextAlignment="Center"
                       IsVisible="{Binding LanguageVisible}"
                       Padding="0,0,10,0"
                       Grid.Row="5" Grid.Column="0"/>

                <Button Text="{Binding LanguageOption}"
                        Style="{DynamicResource PickerButton}"
                        Command="{Binding LanguageChangedCommand}"
                        IsVisible="{Binding LanguageVisible}"
                        Margin="0,10"
                        Grid.Row="5" Grid.Column="1"/>

                <!-- Rating -->
                <Label Text="{x:Static localization:AppStringResources.BookRating}"
                       VerticalTextAlignment="Center"
                       IsVisible="{Binding RatingVisible}"
                       Padding="0,0,10,0"
                       Grid.Row="6" Grid.Column="0"/>

                <Button Text="{Binding RatingOption}"
                        Style="{DynamicResource PickerButton}"
                        Command="{Binding RatingChangedCommand}"
                        IsVisible="{Binding RatingVisible}"
                        Margin="0,10"
                        Grid.Row="6" Grid.Column="1"/>

                <!-- Location -->
                <Label Text="{x:Static localization:AppStringResources.BookLocation}"
                       VerticalTextAlignment="Center"
                       IsVisible="{Binding LocationVisible}"
                       Padding="0,0,10,0"
                       Grid.Row="7" Grid.Column="0"/>

                <Button Text="{Binding LocationOption}"
                        Style="{DynamicResource PickerButton}"
                        Command="{Binding LocationChangedCommand}"
                        IsVisible="{Binding LocationVisible}"
                        Margin="0,10"
                        Grid.Row="7" Grid.Column="1"/>

                <!-- Series -->
                <Label Text="{x:Static localization:AppStringResources.BookSeries}"
                       VerticalTextAlignment="Center"
                       IsVisible="{Binding SeriesVisible}"
                       Padding="0,0,10,0"
                       Grid.Row="8" Grid.Column="0"/>

                <Button Text="{Binding SeriesOption}"
                        Style="{DynamicResource PickerButton}"
                        Command="{Binding SeriesChangedCommand}"
                        IsVisible="{Binding SeriesVisible}"
                        Margin="0,10"
                        Grid.Row="8" Grid.Column="1"/>

                <!-- Book Cover -->
                <Label Text="{x:Static localization:AppStringResources.BookCover}"
                       VerticalTextAlignment="Center"
                       IsVisible="{Binding BookCoverVisible}"
                       Padding="0,0,10,0"
                       Grid.Row="9" Grid.Column="0"/>

                <Button Text="{Binding BookCoverOption}"
                        Style="{DynamicResource PickerButton}"
                        Command="{Binding BookCoverChangedCommand}"
                        IsVisible="{Binding BookCoverVisible}"
                        Margin="0,10"
                        Grid.Row="9" Grid.Column="1"/>

                <!-- Reading Status -->
                <Label Text="{x:Static localization:AppStringResources.ReadingStatus}"
                       VerticalTextAlignment="Center"
                       IsVisible="{Binding ReadingStatusVisible}"
                       Padding="0,0,10,0"
                       Grid.Row="10" Grid.Column="0"/>

                <Button Text="{Binding ReadingStatusOption}"
                        Style="{DynamicResource PickerButton}"
                        Command="{Binding ReadingStatusChangedCommand}"
                        IsVisible="{Binding ReadingStatusVisible}"
                        Margin="0,10"
                        Grid.Row="10" Grid.Column="1"/>

                <!-- Loaned Out -->
                <Label Text="{x:Static localization:AppStringResources.BooksLoanedOut}"
                       VerticalTextAlignment="Center"
                       IsVisible="{Binding LoanedOutBooksVisible}"
                       Padding="0,0,10,0"
                       Grid.Row="11" Grid.Column="0"/>

                <Button Text="{Binding LoanedOutBooksOption}"
                        Style="{DynamicResource PickerButton}"
                        Command="{Binding LoanedOutBooksChangedCommand}"
                        IsVisible="{Binding LoanedOutBooksVisible}"
                        Margin="0,10"
                        Grid.Row="11" Grid.Column="1"/>

                <!-- Borrowed -->
                <Label Text="{x:Static localization:AppStringResources.BooksBorrowed}"
                       VerticalTextAlignment="Center"
                       IsVisible="{Binding BorrowedBooksVisible}"
                       Padding="0,0,10,0"
                       Grid.Row="12" Grid.Column="0"/>

                <Button Text="{Binding BorrowedBooksOption}"
                        Style="{DynamicResource PickerButton}"
                        Command="{Binding BorrowedBooksChangedCommand}"
                        IsVisible="{Binding BorrowedBooksVisible}"
                        Margin="0,10"
                        Grid.Row="12" Grid.Column="1"/>

            </Grid>
        </ScrollView>

        <Grid x:Name="overlaySection"
              Grid.Row="0" Grid.RowSpan="2"/>

    </Grid>

</toolkit:Popup>