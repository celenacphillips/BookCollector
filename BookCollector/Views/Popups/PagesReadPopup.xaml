<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
               x:Class="BookCollector.Views.Popups.PagesReadPopup"
               x:TypeArguments="x:Int32"
               CanBeDismissedByTappingOutsideOfPopup="True"
               WidthRequest="{Binding PopupWidth}"
               BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"
               Margin="0">

    <VerticalStackLayout>

        <Grid Margin="0,10">
                
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Label Text="{x:Static localization:AppStringResources.PagesRead}"
                    Style="{DynamicResource Header}"
                    FontSize="Subtitle"
                    HorizontalOptions="Center"
                    VerticalOptions="End"
                    Grid.Row="0" Grid.Column="0"/>

            <Label x:Name="PagesReadLabel"
                    Style="{DynamicResource Header}"
                    FontSize="Subtitle"
                    VerticalOptions="End"
                    Grid.Row="0" Grid.Column="1"/>

            <Button Text="{x:Static localization:AppStringResources.Save}" 
                    HorizontalOptions="End"
                    Margin="10,10,15,0"
                    Grid.Row="0" Grid.Column="2"
                    Clicked="OnClose"/>
            </Grid>

            <Slider Maximum="{Binding PageTotal}"
                    Minimum="0"
                    Value="{Binding PagesRead}"
                    Margin="20,10,20,30"
                    ValueChanged="OnSliderValueChanged" />
            
        </VerticalStackLayout>
        
</toolkit:Popup>