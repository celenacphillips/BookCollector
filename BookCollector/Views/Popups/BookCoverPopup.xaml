<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
               x:Class="BookCollector.Views.Popups.BookCoverPopup"
               xmlns:controls="clr-namespace:BookCollector.Views.Controls"
               CanBeDismissedByTappingOutsideOfPopup="True"
               BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"
               Margin="0">
    <VerticalStackLayout Padding="20">
        <controls:PinchandPanContainer>
            <Image Source="{Binding BookCover}" />
        </controls:PinchandPanContainer>
    </VerticalStackLayout>
</toolkit:Popup>