<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
               x:Class="BookCollector.Views.Popups.TimePopup"
               x:TypeArguments="x:TimeSpan"
               CanBeDismissedByTappingOutsideOfPopup="True"
               WidthRequest="{Binding PopupWidth}"
               BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"
               x:Name="this"
               Margin="0">

    <VerticalStackLayout BindingContext="{x:Reference this}">

        <Grid Margin="0,10">
                
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Label Text="{Binding Title}"
                   Style="{DynamicResource Header}"
                   FontSize="Subtitle"
                   HorizontalOptions="Center"
                   VerticalOptions="End"
                   Grid.Row="0" Grid.Column="0"/>

            <ImageButton HorizontalOptions="End"
                         Margin="10,10,15,0"
                         Padding="10,5"
                         Grid.Row="0" Grid.Column="2"
                         Clicked="OnClose"
                         IsEnabled="{Binding SaveEnabled}">
                <ImageButton.Source>
                    <FontImageSource FontFamily="MaterialDesignIcons"
                                     Glyph="&#xF0193;"
                                     Size="28"
                                     Color="{AppThemeBinding Light={DynamicResource TextLight}, Dark={DynamicResource TextDark}}" />
                </ImageButton.Source>
            </ImageButton>

        </Grid>

        <Grid Margin="10">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"></ColumnDefinition>
                        <ColumnDefinition Width="2.3*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    
                    <Label Text="{x:Static localization:AppStringResources.Hours}"
                           Style="{DynamicResource Header}"
                           Grid.Row="0" Grid.Column="0"
                           HorizontalOptions="End"/>
                    
                    <Label Text=" *"
                           Style="{DynamicResource Header_Warning}"
                           IsVisible="{Binding HoursNotValid}"
                           Grid.Row="0" Grid.Column="1"
                           HorizontalOptions="Start"/>
                </Grid>
                
                <Editor Text="{Binding Hours}"
                        Placeholder="{x:Static localization:AppStringResources.EnterHours}"
                        HorizontalTextAlignment="Center"
                        Keyboard="Numeric"
                        TextChanged="HoursEditor_TextChanged"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"></ColumnDefinition>
                        <ColumnDefinition Width="2.3*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Label Text="{x:Static localization:AppStringResources.Minutes}"
                           Style="{DynamicResource Header}"
                           Grid.Row="0" Grid.Column="0"
                           HorizontalOptions="End"/>

                    <Label Text=" *"
                           Style="{DynamicResource Header_Warning}"
                           IsVisible="{Binding MinutesNotValid}"
                           Grid.Row="0" Grid.Column="1"
                           HorizontalOptions="Start"/>
                </Grid>
                
                <Editor Text="{Binding Minutes}"
                        Placeholder="{x:Static localization:AppStringResources.EnterMinutes}"
                        HorizontalTextAlignment="Center"
                        Keyboard="Numeric"
                        TextChanged="MinutesEditor_TextChanged"/>
            </VerticalStackLayout>
        </Grid>
            
        </VerticalStackLayout>
        
</toolkit:Popup>