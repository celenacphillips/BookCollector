<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:controls="clr-namespace:BookCollector.Views.Controls"
               xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
               BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"
               x:Class="BookCollector.Views.Popups.FilterableListPopup"
               x:TypeArguments="x:String"
               Margin="0">
    
    <VerticalStackLayout>

        <Label Text="{Binding Title}"
               Style="{DynamicResource Header}"
               FontSize="Subtitle"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Margin="0,10"/>

        <controls:FilterablePicker SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                   Items="{Binding Items}"
                                   ShowFilter="{Binding ShowFilter}"/>
    </VerticalStackLayout>
</toolkit:Popup>
