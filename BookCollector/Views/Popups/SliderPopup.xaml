<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
               xmlns:local="clr-namespace:BookCollector.Views.Popups"
               x:Class="BookCollector.Views.Popups.SliderPopup"
               x:TypeArguments="x:Int32"
               CanBeDismissedByTappingOutsideOfPopup="True"
               WidthRequest="{Binding PopupWidth}"
               BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"
               x:Name="this"
               Margin="0"
               x:DataType="local:SliderPopup">

    <VerticalStackLayout BindingContext="{x:Reference this}">

        <Grid Margin="0,10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Label Text="{Binding Title}"
                    Style="{DynamicResource Header}"
                    FontSize="Subtitle"
                    HorizontalOptions="Center"
                    VerticalOptions="End"
                    Grid.Row="0" Grid.Column="0"/>

            <Editor x:Name="InputValueEditor"
                    FontSize="Subtitle"
                    VerticalOptions="End"
                    Keyboard="Numeric"
                    TextColor="{DynamicResource Primary}"
                    FontAttributes="Bold"
                    HorizontalTextAlignment="Center"
                    Grid.Row="0" Grid.Column="1"
                    Margin="0,-10"
                    TextChanged="InputValueEditor_TextChanged"/>

            <Label Text="*"
                   Style="{DynamicResource Header_Warning}"
                   IsVisible="{Binding InputNotValid}"
                   VerticalOptions="Center"
                   Grid.Row="0" Grid.Column="2"/>

            <ImageButton HorizontalOptions="End"
                         VerticalOptions="Center"
                         Margin="10,10,15,0"
                         Padding="10,5"
                         Grid.Row="0" Grid.Column="3"
                         Clicked="OnClose">
                <ImageButton.Source>
                    <FontImageSource FontFamily="MaterialDesignIcons"
                                     Glyph="&#xF0193;"
                                     Size="28"
                                     Color="{AppThemeBinding Light={DynamicResource TextLight}, Dark={DynamicResource TextDark}}" />
                </ImageButton.Source>
            </ImageButton>

        </Grid>

        <Slider Maximum="{Binding MaxSliderValue}"
                Minimum="0"
                Value="{Binding InputValue}"
                Margin="20,10,20,30"
                ValueChanged="OnSliderValueChanged"
                x:Name="InputSlider"/>
            
        </VerticalStackLayout>
        
</toolkit:Popup>