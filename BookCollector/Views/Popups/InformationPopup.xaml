<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
               x:Class="BookCollector.Views.Popups.InformationPopup"
               CanBeDismissedByTappingOutsideOfPopup="True"
               WidthRequest="{Binding PopupWidth}"
               MinimumHeightRequest="{Binding PopupHeight}"
               BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}"
               Margin="0">

    <VerticalStackLayout>
        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Image HorizontalOptions="Center"
                   Grid.Row="0" Grid.Column="0">
                <Image.Source>
                    <FontImageSource FontFamily="MaterialDesignIcons"
                                     Glyph="&#xF02FC;"
                                     Size="34"
                                     Color="{AppThemeBinding Light={DynamicResource TextLight}, Dark={DynamicResource TextDark}}" />
                </Image.Source>
            </Image>

            <Label Text="{Binding InfoText}"
                   Grid.Row="0" Grid.Column="1"
                   VerticalTextAlignment="Center"
                   Margin="20"/>

        </Grid>

    </VerticalStackLayout>
    
</toolkit:Popup>