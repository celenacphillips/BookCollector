<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
             x:Class="BookCollector.Views.Genre.GenreMainView"
             xmlns:viewModel="clr-namespace:BookCollector.ViewModels.Genre"
             x:DataType="viewModel:GenreMainViewModel"
             xmlns:bookControls="clr-namespace:BookCollector.Views.Controls.Book"
             xmlns:activityControls="clr-namespace:BookCollector.Views.Controls"
             x:Name="GenreMainPage"
             Title="{Binding ViewTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding FilterPopupCommand}"
                     IsEnabled="{Binding IsEnabled}">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="MaterialDesignIcons" 
                                 Glyph="&#xF0236;" 
                                 Size="26" 
                                 Color="{AppThemeBinding Light={DynamicResource TextLight}, Dark={DynamicResource TextDark}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>

        <ToolbarItem Command="{Binding SortPopupCommand}"
                     IsEnabled="{Binding IsEnabled}">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="MaterialDesignIcons" 
                                 Glyph="&#xF04BA;" 
                                 Size="26" 
                                 Color="{AppThemeBinding Light={DynamicResource TextLight}, Dark={DynamicResource TextDark}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>

        <ToolbarItem Command="{Binding InfoPopupCommand}">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="MaterialDesignIcons" 
                                 Glyph="&#xF02FC;" 
                                 Size="26" 
                                 Color="{AppThemeBinding Light={DynamicResource TextLight}, Dark={DynamicResource TextDark}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        
        <ToolbarItem Text="{x:Static localization:AppStringResources.AddNewBook}"
                     Order="Secondary"
                     Command="{Binding AddNewBookCommand}"
                     IsEnabled="{Binding IsEnabled}"/>
        
        <ToolbarItem Text="{x:Static localization:AppStringResources.AddExistingBook}"
                     Order="Secondary"
                     Command="{Binding AddExistingBookCommand}"
                     IsEnabled="{Binding IsEnabled}"/>
    </ContentPage.ToolbarItems>

    <Grid>

        <!-- Main Content -->
        <StackLayout>

            <RefreshView IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshCommand}">

                <VerticalStackLayout IsVisible="{Binding IsVisible}">
                    <Label Text="{Binding TotalBooksString}"
                           HorizontalOptions="End"
                           Margin="0,0,20,0"
                           TextColor="{StaticResource Primary}"
                           Style="{StaticResource SubTitle}"/>

                    <ScrollView>
                        <!-- This is needed to allow the refresh view to work. -->
                        <VerticalStackLayout  Padding="10">
                            <SearchBar Placeholder="{x:Static localization:AppStringResources.SearchBooks}"
                                       Text="{Binding Searchstring}">
                                <SearchBar.Behaviors>
                                    <toolkit:EventToCommandBehavior Command="{Binding BookSearchOnTitleCommand}"
                                                                    CommandParameter="{Binding Searchstring}"
                                                                    EventName="TextChanged"
                                                                    BindingContext="{Binding BindingContext, Source={x:Reference GenreMainPage}}"/>
                                </SearchBar.Behaviors>
                            </SearchBar>

                            <bookControls:BookCollectionList/>

                        </VerticalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>
            </RefreshView>

        </StackLayout>
        <!-- Main Content -->

        <!-- Activity Indicator -->
        <activityControls:LoadingControl/>
        <!-- Activity Indicator -->
    </Grid>
    
</ContentPage>