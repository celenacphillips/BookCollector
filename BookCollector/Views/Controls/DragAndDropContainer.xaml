<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BookCollector.Views.Controls"
             xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
             x:Class="BookCollector.Views.Controls.DragAndDropContainer"
             x:Name="this"
             x:DataType="local:DragAndDropContainer">

    <VerticalStackLayout BindingContext="{x:Reference this}">

        <VerticalStackLayout x:Name="ItemsStackLayout"
                             Spacing="5"
                             Padding="20">
        </VerticalStackLayout>
        
    </VerticalStackLayout>

</ContentView>
