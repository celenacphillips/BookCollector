<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:localization="clr-namespace:BookCollector.Resources.Localization"
             x:Class="BookCollector.Views.Controls.Collection.CollectionCollectionItem"
             xmlns:viewModel="clr-namespace:BookCollector.ViewModels.Groupings"
             xmlns:dataModels="clr-namespace:BookCollector.Data.Models">

    <VerticalStackLayout>
        <Grid HeightRequest="50"
              Margin="10,10,0,10"
              x:DataType="dataModels:CollectionModel">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="6*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Image HorizontalOptions="Center"
                   Grid.Row="0" Grid.Column="0">
                <Image.Source>
                    <FontImageSource FontFamily="MaterialDesignIcons"
                                     Glyph="&#xF196C;"
                                     Size="34"
                                     Color="{AppThemeBinding Light={DynamicResource TextLight}, Dark={DynamicResource TextDark}}" />
                </Image.Source>
            </Image>

            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Start"
                                 Grid.Row="0" Grid.Column="1"
                                 Padding="10,0,0,0">
                
                <Label Text="{Binding CollectionName}"
                       TextColor="{DynamicResource Primary}"/>

                <Label Text="{Binding TotalBooksString}"
                       Style="{DynamicResource SubTitle}"
                       FontSize="12"/>
            </VerticalStackLayout>

            <HorizontalStackLayout Grid.Row="0" Grid.Column="2"
                                   HorizontalOptions="End">
                <ImageButton HorizontalOptions="End"
                             Command="{Binding Source={RelativeSource AncestorType={x:Type viewModel:CollectionsViewModel}}, Path=PopupMenuCollectionCommand}"
                             CommandParameter="{Binding CollectionGuid}"
                             BackgroundColor="Transparent"
                             Padding="10,0">
                    <ImageButton.Source>
                        <FontImageSource FontFamily="MaterialDesignIcons"
                                         Glyph="&#xF01D9;"
                                         Size="24"
                                         Color="{AppThemeBinding Light={DynamicResource TextLight}, Dark={DynamicResource TextDark}}" />
                    </ImageButton.Source>
                </ImageButton>
            </HorizontalStackLayout>
        </Grid>

        <Label Style="{DynamicResource LongSeparator}"/>

    </VerticalStackLayout>
</ContentView>
