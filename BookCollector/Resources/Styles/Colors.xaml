<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#336699</Color>
    <Color x:Key="Secondary">#3F7FBF</Color>
    <Color x:Key="Tertiary">#6599CC</Color>

    <Color x:Key="Color2">#329951</Color>
    <Color x:Key="Color3">#8E9932</Color>
    <Color x:Key="Color4">#99323D</Color>
    <Color x:Key="Color5">#7A3299</Color>
    <Color x:Key="Color6">#7A3299</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>
    <Color x:Key="Warning">Red</Color>
    <Color x:Key="UnselectedText">#ACACAC</Color>
    <Color x:Key="UnselectedBackground">#C8C8C8</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Light -->
    <Color x:Key="SecondaryLight">#4080bf</Color>
    <Color x:Key="TertiaryLight">#6699cc</Color>
    <Color x:Key="MenuLight">Black</Color>
    <Color x:Key="BackgroundLight">#f2f2f2</Color>
    <Color x:Key="SecondaryBackgroundLight">#e6e6e6</Color>
    <Color x:Key="TextLight">Black</Color>
    <Color x:Key="SecondaryTextLight">White</Color>

    <!-- Dark -->
    <Color x:Key="SecondaryDark">#538cc6</Color>
    <Color x:Key="TertiaryDark">#8cb3d9</Color>
    <Color x:Key="MenuDark">#f2f2f2</Color>
    <Color x:Key="BackgroundDark">#1f1f1f</Color>
    <Color x:Key="SecondaryBackgroundDark">#333333</Color>
    <Color x:Key="TextDark">White</Color>
    <Color x:Key="SecondaryTextDark">Black</Color>

    <SolidColorBrush x:Key="TertiaryBrush" Color="{DynamicResource Tertiary}" />
</ResourceDictionary>